{
  "name": "tiny-invoice",
  "version": "1.8.15",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "doppler run -- pnpm -r build",
    "ship": "npx tsx tools/ship.ts",
    "build:plugins": "pnpm --filter @narduk/eslint-config build",
    "prelint": "pnpm run build:plugins",
    "lint": "pnpm run prelint && turbo run lint",
    "typecheck": "turbo run typecheck",
    "quality": "turbo run quality --filter='./apps/*'",
    "setup": "npx tsx tools/init.ts",
    "update-layer": "npx tsx tools/update-layer.ts",
    "validate": "doppler run -- jiti tools/validate.ts",
    "clean": "find . -type d \\( -name node_modules -o -name .nuxt -o -name .output -o -name .nitro -o -name .wrangler -o -name .turbo -o -name .data -o -name dist \\) -not -path './.git/*' -prune -exec rm -rf {} +",
    "clean:install": "pnpm run clean && pnpm install && pnpm run db:ready:all",
    "db:migrate": "pnpm --filter web run db:migrate",
    "db:seed": "pnpm --filter web run db:seed",
    "db:ready": "pnpm --filter web run db:ready",
    "dev:kill": "sh scripts/dev-kill.sh",
    "test:e2e": "playwright test",
    "test:e2e:production": "BASE_URL=https://tiny-invoice.nard.uk playwright test",
    "generate:favicons": "npx tsx tools/generate-favicons.ts",
    "predev": "node tools/check-setup.cjs",
    "prebuild": "node tools/check-setup.cjs",
    "preship": "node tools/check-setup.cjs && pnpm install --frozen-lockfile && npx tsx tools/check-drift-ci.ts && npx tsx tools/check-sync-health.ts && pnpm run quality",
    "postinstall": "node -e \"if(!require('fs').existsSync('.setup-complete'))console.log('\\n⚠️  Run pnpm run setup before doing anything else! See AGENTS.md.\\n')\"",
    "predeploy": "node tools/check-setup.cjs",
    "format": "prettier --write \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\" --ignore-path .gitignore",
    "tail": "npx tsx tools/tail.ts",
    "check:sync-health": "npx tsx tools/check-sync-health.ts",
    "quality:fix": "turbo run lint --force -- --fix && pnpm run format"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "serialize-javascript": ">=7.0.3",
      "@cloudflare/unenv-preset": "2.12.1",
      "nuxt-og-image": "6.0.0-beta.47",
      "@takumi-rs/core": ">=0.70.1",
      "@takumi-rs/wasm": ">=0.70.1",
      "@cloudflare/workers-types": "4.20260307.1",
      "@typescript-eslint/utils": "^8.57.0",
      "@nuxt/eslint": "^1.15.2",
      "eslint-plugin-unicorn": "^63.0.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  },
  "volta": {
    "node": "22.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.19.13",
    "concurrently": "^9.2.1",
    "sharp": "^0.34.5",
    "turbo": "^2.8.12",
    "tsx": "^4.21.0",
    "prettier": "^3.8.1"
  }
}
