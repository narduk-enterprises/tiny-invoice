{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/schemas/config/wrangler.json",
  "name": "tiny-invoice",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2026-03-03",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tiny-invoice-db",
      "database_id": "e2260a6b-cdb6-47dd-aaa4-f0f39c2d7f5f"
    }
  ],
  "routes": [
    { "pattern": "tiny-invoice.nard.uk", "custom_domain": true }
  ]
}
